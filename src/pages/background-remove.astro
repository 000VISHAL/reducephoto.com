---
import Layout from '../layouts/Layout.astro';
import ImageDropzone from '../components/ImageDropzone.astro';
---

<Layout
  title="Background Remover - Make Photo Background White | Reduce Photo Size"
  description="Remove photo backgrounds and replace them with pure white. Meets official UPSC, SSC, and passport photo guidelines using a local client-side canvas flood-fill."
>
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-12 lg:py-16 space-y-8 transition-all duration-150" id="bg-remove-container">
    <!-- Breadcrumb -->
    <nav class="text-[13px] text-[var(--color-text-muted)] flex items-center gap-2">
      <a href="/" class="hover:text-[var(--color-text-secondary)] transition-colors">Home</a>
      <span>/</span>
      <span class="text-[var(--color-text-secondary)] font-medium">Background Remover</span>
    </nav>

    <!-- Header Section -->
    <div class="border-b border-[var(--color-border-subtle)] pb-6 space-y-2.5 max-w-xl">
      <h1 class="text-[32px] font-bold text-[var(--color-text-primary)] leading-tight tracking-tight">
        White Background Replacer
      </h1>
      <p class="text-[15px] text-[var(--color-text-secondary)]">
        Instantly replace light or uneven backgrounds with pure white (<code>#ffffff</code>). Adjust the sensitivity slider to tweak edge detection.
      </p>
    </div>

    <!-- Main Workspace -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left Controls (4 cols) -->
      <div class="lg:col-span-4 space-y-6">
        <div class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] p-5 space-y-4">
          <h2 class="text-[16px] font-bold text-[var(--color-text-primary)]">Settings</h2>

          <!-- Sensitivity threshold slider -->
          <div class="space-y-2">
            <div class="flex justify-between text-[13px]">
              <label for="slider-threshold" class="text-[var(--color-text-secondary)]">Sensitivity Threshold</label>
              <span id="val-threshold" class="text-[var(--color-text-primary)] font-medium">35</span>
            </div>
            <input type="range" id="slider-threshold" min="10" max="60" value="35" class="w-full h-1 bg-[var(--color-border)] rounded-full appearance-none cursor-pointer accent-[var(--color-accent)]" />
            <p class="text-[11px] text-[var(--color-text-muted)]">Increase if shadows are left behind. Decrease if edges of candidate's clothes turn white.</p>
          </div>

          <!-- Actions -->
          <div class="pt-4 border-t border-[var(--color-border-subtle)] space-y-2">
            <button
              type="button"
              id="btn-remove-bg-action"
              class="w-full bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-[var(--color-text-inverse)] text-[14px] font-semibold py-2.5 rounded-[6px] transition-colors focus-ring hidden"
            >
              Replace Background
            </button>
            <a
              href="#"
              id="btn-remove-bg-download"
              download="reducephoto-white-bg.jpg"
              class="w-full bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-[var(--color-text-inverse)] text-[14px] font-semibold py-2.5 rounded-[6px] transition-colors focus-ring text-center block hidden"
            >
              Download as JPG
            </a>
            <button
              type="button"
              id="btn-remove-bg-reset"
              class="w-full border border-[var(--color-border)] hover:border-[var(--color-border-focus)] hover:bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] text-[13px] font-medium py-2 rounded-[6px] transition-colors hidden"
            >
              Remove Another
            </button>
          </div>
        </div>
      </div>

      <!-- Right Output Panel (8 cols) -->
      <div class="lg:col-span-8 space-y-6">
        <div class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] p-6 space-y-6">
          <ImageDropzone id="bg-remove-upload" maxSizeMB={15} />

          <!-- Side-by-Side Preview Grid -->
          <div id="bg-remove-preview-container" class="hidden space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-2">
                <h3 class="text-[13px] font-bold text-[var(--color-text-secondary)] text-center">Original Image</h3>
                <div class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg)] p-3 flex items-center justify-center h-[260px]">
                  <img id="img-orig-preview" class="max-h-full max-w-full object-contain rounded-[4px]" alt="Original Upload" />
                </div>
              </div>
              <div class="space-y-2">
                <h3 class="text-[13px] font-bold text-[var(--color-text-secondary)] text-center">Processed (White BG)</h3>
                <div class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg)] p-3 flex items-center justify-center h-[260px]">
                  <img id="img-proc-preview" class="max-h-full max-w-full object-contain rounded-[4px]" alt="Processed Output" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  let uploadedFile: { file: File; dataUrl: string; width: number; height: number } | null = null;
  let processedDataUrl: string | null = null;

  const container = document.getElementById('bg-remove-container');
  if (container) {
    const btnAction = container.querySelector('#btn-remove-bg-action') as HTMLButtonElement;
    const btnDownload = container.querySelector('#btn-remove-bg-download') as HTMLAnchorElement;
    const btnReset = container.querySelector('#btn-remove-bg-reset') as HTMLButtonElement;

    const thresholdSlider = container.querySelector('#slider-threshold') as HTMLInputElement;
    const thresholdVal = container.querySelector('#val-threshold') as HTMLElement;

    const previewContainer = container.querySelector('#bg-remove-preview-container') as HTMLElement;
    const imgOrigPreview = container.querySelector('#img-orig-preview') as HTMLImageElement;
    const imgProcPreview = container.querySelector('#img-proc-preview') as HTMLImageElement;

    thresholdSlider.addEventListener('input', (e) => {
      thresholdVal.textContent = (e.target as HTMLInputElement).value;
      if (uploadedFile) {
        btnAction.classList.remove('hidden');
        btnDownload.classList.add('hidden');
      }
    });

    // File Selected
    container.addEventListener('file-selected', (e: any) => {
      uploadedFile = e.detail;
      if (uploadedFile) {
        imgOrigPreview.src = uploadedFile.dataUrl;
        btnAction.classList.remove('hidden');
      }
    });

    container.addEventListener('file-removed', () => {
      uploadedFile = null;
      previewContainer.classList.add('hidden');
      btnAction.classList.add('hidden');
      btnDownload.classList.add('hidden');
      btnReset.classList.add('hidden');
    });

    // Replace background click handler
    btnAction.addEventListener('click', () => {
      if (!uploadedFile) return;

      const sensitivity = parseInt(thresholdSlider.value);
      const img = new Image();
      img.onload = () => {
        // Create canvas (Limit max size to 800px to keep flood fill extremely responsive)
        const canvas = document.createElement('canvas');
        const maxDim = 800;
        let w = img.width;
        let h = img.height;

        if (w > maxDim || h > maxDim) {
          if (w > h) {
            h = Math.round((h * maxDim) / w);
            w = maxDim;
          } else {
            w = Math.round((w * maxDim) / h);
            h = maxDim;
          }
        }

        canvas.width = w;
        canvas.height = h;

        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        // Draw downscaled original
        ctx.drawImage(img, 0, 0, w, h);

        // Run BFS flood fill from sampled border seeds
        const imgData = ctx.getImageData(0, 0, w, h);
        const data = imgData.data;
        const originalData = new Uint8ClampedArray(data);
        const visited = new Uint8Array(w * h);
        const queue: number[] = [];

        // Sample seeds along borders (top, left, right)
        const seeds: [number, number][] = [];
        
        // Top edge (excluding middle where the head usually is)
        for (let x = 0; x < w * 0.35; x += 4) {
          seeds.push([x, 0]);
          seeds.push([w - 1 - x, 0]);
        }
        // Left and Right edges (top 85%)
        for (let y = 0; y < h * 0.85; y += 4) {
          seeds.push([0, y]);
          seeds.push([w - 1, y]);
        }

        // Filter seeds to only keep light/background-like pixels
        const validSeeds: { x: number; y: number; r: number; g: number; b: number }[] = [];
        seeds.forEach(([sx, sy]) => {
          const idx = (sy * w + sx) * 4;
          const r = originalData[idx];
          const g = originalData[idx + 1];
          const b = originalData[idx + 2];
          const brightness = (r + g + b) / 3;
          
          const maxVal = Math.max(r, g, b);
          const minVal = Math.min(r, g, b);
          const sat = maxVal === 0 ? 0 : (maxVal - minVal) / maxVal;

          // Check if it is a light background pixel (not hair or clothing)
          if (brightness > 90 && sat < 0.6) {
            validSeeds.push({ x: sx, y: sy, r, g, b });
          }
        });

        // Fallback to corners if no valid seeds
        if (validSeeds.length === 0) {
          const corners = [
            [0, 0],
            [w - 1, 0],
            [0, h - 1],
            [w - 1, h - 1]
          ];
          corners.forEach(([cx, cy]) => {
            const idx = (cy * w + cx) * 4;
            validSeeds.push({ x: cx, y: cy, r: originalData[idx], g: originalData[idx+1], b: originalData[idx+2] });
          });
        }

        const maxDistSq = sensitivity * sensitivity * 3;

        validSeeds.forEach((seed) => {
          const key = seed.y * w + seed.x;
          if (visited[key]) return;

          visited[key] = 1;
          queue.push(seed.x, seed.y);

          const startR = seed.r;
          const startG = seed.g;
          const startB = seed.b;

          let qHead = 0;
          while (qHead < queue.length) {
            const x = queue[qHead++];
            const y = queue[qHead++];

            const idx = (y * w + x) * 4;
            data[idx] = 255;
            data[idx + 1] = 255;
            data[idx + 2] = 255;
            data[idx + 3] = 255;

            const neighbors = [
              [x + 1, y],
              [x - 1, y],
              [x, y + 1],
              [x, y - 1]
            ];

            for (let i = 0; i < neighbors.length; i++) {
              const nx = neighbors[i][0];
              const ny = neighbors[i][1];

              if (nx >= 0 && nx < w && ny >= 0 && ny < h) {
                const nkey = ny * w + nx;
                if (!visited[nkey]) {
                  const nIdx = nkey * 4;
                  const r = originalData[nIdx];
                  const g = originalData[nIdx + 1];
                  const b = originalData[nIdx + 2];
                  const a = originalData[nIdx + 3];

                  if (a < 10) {
                    visited[nkey] = 1;
                    queue.push(nx, ny);
                    continue;
                  }

                  const dr = r - startR;
                  const dg = g - startG;
                  const db = b - startB;
                  const distSq = dr * dr + dg * dg + db * db;

                  if (distSq <= maxDistSq) {
                    visited[nkey] = 1;
                    queue.push(nx, ny);
                  }
                }
              }
            }
          }
          queue.length = 0;
        });

        // Write processed data back to canvas
        ctx.putImageData(imgData, 0, 0);

        const outUrl = canvas.toDataURL('image/jpeg', 0.9);
        processedDataUrl = outUrl;
        imgProcPreview.src = outUrl;

        // UI toggles
        previewContainer.classList.remove('hidden');
        btnDownload.classList.remove('hidden');
        btnReset.classList.remove('hidden');
        btnAction.classList.add('hidden');

        btnDownload.href = outUrl;
      };
      img.src = uploadedFile.dataUrl;
    });

    btnReset.addEventListener('click', () => {
      const removeBtnInside = container.querySelector('#bg-remove-upload-remove-btn') as HTMLButtonElement;
      if (removeBtnInside) removeBtnInside.click();
    });
  }
</script>
