---
import Layout from '../layouts/Layout.astro';
import { exams } from '../data/exams';

// Categories for UI tabs
const categories = [
  { id: 'all', label: 'All Presets' },
  { id: 'central', label: 'Central Government' },
  { id: 'state', label: 'State PSCs' },
  { id: 'banking', label: 'Banking & Finance' },
  { id: 'police', label: 'Police & Paramilitary' },
  { id: 'judiciary', label: 'Judiciary & Law' },
];
---

<Layout
  title="Browse 100+ Government Exam Photo Size Presets | Reduce Photo Size"
  description="Find official image specifications (dimensions, file size in KB, format) for UPSC, SSC, Banking, Police, State PSCs, and Judiciary exams."
>
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-12 lg:py-20 space-y-10 transition-all duration-150">
    <!-- Breadcrumb -->
    <nav class="text-[13px] text-[var(--color-text-muted)] flex items-center gap-2">
      <a href="/" class="hover:text-[var(--color-text-secondary)] transition-colors">Home</a>
      <span>/</span>
      <span class="text-[var(--color-text-secondary)] font-medium">Exams</span>
    </nav>

    <!-- Header Section -->
    <div class="space-y-4 max-w-2xl">
      <h1 class="text-[36px] font-bold text-[var(--color-text-primary)] leading-tight tracking-tight">
        Official Exam Preset Database
      </h1>
      <p class="text-[15px] leading-relaxed text-[var(--color-text-secondary)]">
        Find size and format specifications for recruitment and entrance exams in India. Click on any preset to open the resizer pre-filled with those exact settings.
      </p>
    </div>

    <!-- Live Search & Category Tabs -->
    <div class="space-y-6 border-t border-[var(--color-border-subtle)] pt-8" id="exams-container">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <!-- Search bar -->
        <div class="relative max-w-md w-full">
          <input
            type="text"
            id="exam-database-search"
            placeholder="Search exam presets (e.g. UPSC, SBI, State PSC)..."
            class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3.5 py-2.5 text-[14px] text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:border-[var(--color-border-focus)] outline-none transition-colors"
          />
          <div class="absolute right-3.5 top-3 text-[var(--color-text-muted)] pointer-events-none">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
        </div>

        <!-- Filter tabs -->
        <div class="flex flex-wrap gap-1.5 overflow-x-auto pb-1">
          {categories.map((cat, i) => (
            <button
              type="button"
              data-tab={cat.id}
              class={`category-tab ${i === 0 ? 'active' : ''}`}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Presets Grid -->
      <div id="exams-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {exams.map((exam) => (
          <a
            href={`/exam/${exam.id}`}
            data-name={exam.name}
            data-category={exam.category}
            class="exam-card border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] p-5 hover:border-[var(--color-border-focus)] transition-all duration-150 flex flex-col justify-between group"
          >
            <div class="space-y-3">
              <div class="flex items-start justify-between gap-2">
                <h3 class="text-[16px] font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors leading-snug">
                  {exam.name}
                </h3>
                <span class="text-[11px] capitalize bg-[var(--color-bg-elevated)] border border-[var(--color-border)] text-[var(--color-text-secondary)] px-2 py-0.5 rounded-[4px] flex-shrink-0">
                  {exam.category}
                </span>
              </div>
              
              <div class="grid grid-cols-2 gap-4 text-[13px] border-t border-[var(--color-border-subtle)] pt-3">
                <div class="space-y-1">
                  <span class="text-[11px] text-[var(--color-text-muted)] uppercase tracking-wider block">Photograph</span>
                  <div class="font-medium text-[var(--color-text-primary)]">
                    {exam.photo.width}x{exam.photo.height} px
                  </div>
                  <div class="text-[12px] text-[var(--color-text-secondary)]">
                    {exam.photo.minKB}-{exam.photo.maxKB} KB • {exam.photo.format.toUpperCase()}
                  </div>
                </div>
                <div class="space-y-1 border-l border-[var(--color-border-subtle)] pl-4">
                  <span class="text-[11px] text-[var(--color-text-muted)] uppercase tracking-wider block">Signature</span>
                  <div class="font-medium text-[var(--color-text-primary)]">
                    {exam.signature.width}x{exam.signature.height} px
                  </div>
                  <div class="text-[12px] text-[var(--color-text-secondary)]">
                    {exam.signature.minKB}-{exam.signature.maxKB} KB • {exam.signature.format.toUpperCase()}
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-4 pt-3 border-t border-[var(--color-border-subtle)] flex items-center justify-between text-[13px] text-[var(--color-accent)] font-semibold">
              <span>Use Preset</span>
              <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <!-- No Presets Found -->
      <div id="no-presets" class="hidden text-center py-16 border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)]">
        <svg class="w-10 h-10 text-[var(--color-text-muted)] mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <h3 class="text-[15px] font-semibold text-[var(--color-text-primary)]">No presets match your search</h3>
        <p class="text-[13px] text-[var(--color-text-muted)] mt-1">Try typing another exam name or browse different categories.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .category-tab {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s ease;
  }
  .category-tab:hover {
    color: var(--color-text-primary);
  }
  .category-tab.active {
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    border-color: rgba(0, 208, 132, 0.2);
  }
</style>

<script>
  const container = document.getElementById('exams-container');
  if (container) {
    const searchInput = container.querySelector('#exam-database-search') as HTMLInputElement;
    const tabs = container.querySelectorAll('.category-tab');
    const cards = container.querySelectorAll('.exam-card');
    const grid = container.querySelector('#exams-grid');
    const noPresets = container.querySelector('#no-presets');

    let currentCategory = 'all';
    let searchQuery = '';

    function filterCards() {
      let visibleCount = 0;

      cards.forEach((cardNode) => {
        const card = cardNode as HTMLElement;
        const name = card.dataset.name?.toLowerCase() || '';
        const cat = card.dataset.category || '';

        const matchesSearch = name.includes(searchQuery);
        const matchesCategory = currentCategory === 'all' || cat === currentCategory;

        if (matchesSearch && matchesCategory) {
          card.style.display = 'flex';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (visibleCount === 0) {
        grid?.classList.add('hidden');
        noPresets?.classList.remove('hidden');
      } else {
        grid?.classList.remove('hidden');
        noPresets?.classList.add('hidden');
      }
    }

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
        filterCards();
      });
    }

    tabs.forEach((tabNode) => {
      tabNode.addEventListener('click', () => {
        tabs.forEach((t) => t.classList.remove('active'));
        tabNode.classList.add('active');
        currentCategory = tabNode.getAttribute('data-tab') || 'all';
        filterCards();
      });
    });
  }
</script>
