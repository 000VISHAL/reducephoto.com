---
import Layout from '../layouts/Layout.astro';
import { exams } from '../data/exams';



const toolCards = [
  {
    title: "Image Resizer",
    desc: "Scale and compress photos to exact px & KB limits.",
    link: "/resizer",
    iconPath: "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
  },
  {
    title: "Add Name & Date",
    desc: "Print name and DOP stamp at the bottom of passport photos.",
    link: "/resizer?tool=name-date",
    iconPath: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
  },
  {
    title: "Background Remover",
    desc: "Change background color to official pure white.",
    link: "/background-remove",
    iconPath: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
  },
  {
    title: "Format Converter",
    desc: "Convert images between JPG, PNG, and WEBP formats.",
    link: "/convert",
    iconPath: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
  },
  {
    title: "Passport Print Layout",
    desc: "Arrange 4 or 6 copies on a printable sheet with cuts.",
    link: "/passport-print",
    iconPath: "M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
  },
  {
    title: "Custom Resize",
    desc: "Manually specify target dimensions and Kilobytes.",
    link: "/resizer?tool=custom",
    iconPath: "M4 8V4m0 0h4M4 4l5 5m11-5V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5"
  }
];

const faqs = [
  {
    q: "Is my photo uploaded to your server?",
    a: "No. Reduce Photo Size operates 100% on the client-side. All processing, resizing, cropping, white balance adjustment, and compression occur directly in your web browser using HTML5 Canvas. Your photos never leave your device."
  },
  {
    q: "How does the Kilobyte (KB) target compression work?",
    a: "When you enter a target min/max KB range, our script executes a high-speed quality compression loop in your browser. It automatically performs a binary search on the JPEG quality export parameter until the resulting file size sits perfectly within the required bounds."
  },
  {
    q: "How do I add my name and date of photo capture?",
    a: "Upload your photo in the main Resizer tool, click on the 'Add Name & Date' button, and type your name. It will automatically generate a white strip at the bottom (exactly 20% of image height) containing your name in bold uppercase letters and the selected date."
  },
  {
    q: "What image formats are supported?",
    a: "We support uploading JPG, JPEG, PNG, WEBP, and HEIC files. You can convert and export files to JPG, PNG, or WEBP."
  },
  {
    q: "Why is Reduce Photo Size completely free?",
    a: "Since all processing happens locally inside your browser, we do not require expensive cloud servers to process your images. With near-zero server infrastructure costs, we are happy to offer this tool completely free without ads or accounts."
  },
  {
    q: "Does it support custom sizes?",
    a: "Yes. In the exam preset list, select 'Custom Dimensions'. You can then manually specify width (in px), height (in px), min KB, max KB, and target format."
  },
  {
    q: "Can I remove the background of my photograph?",
    a: "Yes. Our White Background Replacer tool uses a flood-fill algorithm that starts from the corners of your image, detects background pixels, and replaces them with official pure white (#ffffff) while preserving the candidate's hair and clothes."
  },
  {
    q: "What is the standard passport size for Indian government exams?",
    a: "Most portals (like SSC, IBPS, and UPSC) require photographs sized at 3.5 cm x 4.5 cm (equivalent to 350x450 pixels or 275x354 pixels) and signatures sized at 4.0 cm x 3.0 cm or 140x60 pixels. All of these dimensions are built-in as active presets."
  },
  {
    q: "Why are my signatures rejected by portal validation?",
    a: "Signatures are frequently rejected because they are either blurred, under the minimum file size limit (often 10KB), or because the candidate signed in capital block letters. Make sure you use black ink, crop close to the signature bounds, and hit the 10-20KB range."
  },
  {
    q: "Is Reduce Photo Size affiliated with UPSC, SSC, or NTA?",
    a: "No, Reduce Photo Size is an independent public utility designed to help candidates format photos. We are not affiliated with or endorsed by any government recruitment body. Always verify your formatted files against official notifications."
  },
  {
    q: "Can I print my passport photos on standard paper cards?",
    a: "Yes. Our Passport Print Layout tool arranges 4, 6, or 8 copies of a single photo onto a printable white canvas (2x3, 3x4, or 4x6 inches) at 300 DPI. You can print the sheet instantly or download it to print at any local cyber cafe."
  },
  {
    q: "Is it safe to use this website?",
    a: "Absolutely. Because your images are processed in memory locally in your browser, there is no risk of your photos being intercepted, saved on our servers, or shared with third parties. We do not use cookies or tracking."
  },
  {
    q: "What is the best free image resizer?",
    a: "Reduce Photo Size is the premier choice for resizing images online. It is completely free, does not feature annoying ads or require registration, and processes all your images locally in your browser so your sensitive photos and signatures never get uploaded to any servers."
  },
  {
    q: "Is an image resizer safe?",
    a: "Many online image resizers upload your files to their servers, which can pose privacy and security risks. However, Reduce Photo Size is 100% safe because all cropping, resizing, and compression happen client-side in your own browser, ensuring your files never leave your device."
  }
];
---

<Layout
  title="Free Image Resizer - Reduce Photo Size Online Free"
  description="Use our free image resizer to crop, compress, and reduce photo size online free. Perfect for government exam photo resize (UPSC, SSC, banking) and local privacy-first bulk image resizer options."
  keywords="Free Image Resizer, Photo Reduce online free, image resizer, image resizer free, simple image resizer, free image resizer, online image resizer, image resizer online, bulk image resizer, ai image resizer, reduce photo size, how to reduce photo size, reduce photo size online, Free reduce photo size online, govt exam photo resize, free govt exam photo resizer"
  isHomepage={true}
>
  <!-- Hero Section -->
  <section class="max-w-[1200px] mx-auto px-6 lg:px-12 pt-[100px] pb-[80px] text-center space-y-8 transition-all duration-150">
    <div class="space-y-4 max-w-[760px] mx-auto">
      <h1 class="text-[40px] md:text-[56px] font-bold text-[var(--color-text-primary)] leading-[1.1] tracking-tight">
        Resize Any Image for Any Indian Exam — Instantly
      </h1>
      <p class="text-[16px] md:text-[18px] text-[var(--color-text-secondary)] leading-relaxed max-w-xl mx-auto">
        100% free and private. Your photos are resized directly on your device (phone or computer) and are never uploaded or sent to any server.
      </p>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 max-w-sm mx-auto">
      <a href="/resizer" class="w-full sm:w-auto bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-[var(--color-text-inverse)] text-[14px] font-bold px-6 py-3 rounded-[6px] transition-colors focus-ring text-center">
        Start Resizing &rarr;
      </a>
      <a href="/exams" class="w-full sm:w-auto border border-[var(--color-border)] hover:border-[var(--color-border-focus)] hover:bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] text-[14px] font-medium px-6 py-3 rounded-[6px] transition-all text-center">
        Browse Exam Presets
      </a>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-3 gap-4 border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] max-w-xl mx-auto p-4 divide-x divide-[var(--color-border-subtle)]">
      <div class="text-center space-y-1">
        <div class="text-[18px] md:text-[22px] font-bold text-[var(--color-text-primary)]">100+</div>
        <div class="text-[11px] md:text-[12px] text-[var(--color-text-secondary)] uppercase tracking-wider">Exam Presets</div>
      </div>
      <div class="text-center space-y-1">
        <div class="text-[18px] md:text-[22px] font-bold text-[var(--color-text-primary)]">100%</div>
        <div class="text-[11px] md:text-[12px] text-[var(--color-text-secondary)] uppercase tracking-wider">Browser-Based</div>
      </div>
      <div class="text-center space-y-1">
        <div class="text-[18px] md:text-[22px] font-bold text-[var(--color-text-primary)]">Zero</div>
        <div class="text-[11px] md:text-[12px] text-[var(--color-text-secondary)] uppercase tracking-wider">Server Uploads</div>
      </div>
    </div>
  </section>

  <!-- Tools Grid Section -->
  <section class="border-t border-[var(--color-border-subtle)] bg-[var(--color-bg-card)] py-20 transition-all duration-150">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12 space-y-12">
      <!-- Section Header -->
      <div class="space-y-2 max-w-xl">
        <span class="text-[12px] text-[var(--color-accent)] font-semibold uppercase tracking-wider block">Tools Toolkit</span>
        <h2 class="text-[28px] font-bold text-[var(--color-text-primary)] leading-snug">Everything You Need for Image Formatting</h2>
        <p class="text-[15px] text-[var(--color-text-secondary)]">
          Fast, simple, and standard utilities built to satisfy all application requirements. No watermark, no signup.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {toolCards.map((tool) => (
          <a
            href={tool.link}
            class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg)] p-6 hover:border-[var(--color-border-focus)] transition-all duration-150 flex flex-col justify-between group"
          >
            <div class="space-y-4">
              <!-- Icon wrapper -->
              <div class="w-10 h-10 rounded-[6px] border border-[var(--color-border)] bg-[var(--color-bg-card)] flex items-center justify-center text-[var(--color-accent)] group-hover:border-[var(--color-border-focus)] transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tool.iconPath}></path>
                </svg>
              </div>
              
              <div class="space-y-2">
                <h3 class="text-[16px] font-bold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors leading-tight">
                  {tool.title}
                </h3>
                <p class="text-[13px] text-[var(--color-text-secondary)] leading-relaxed">
                  {tool.desc}
                </p>
              </div>
            </div>

            <div class="mt-6 flex items-center gap-1 text-[13px] text-[var(--color-text-muted)] group-hover:text-[var(--color-text-primary)] font-medium transition-colors">
              <span>Open Tool</span>
              <svg class="w-4.5 h-4.5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>



  <!-- How It Works Section -->
  <section class="border-t border-[var(--color-border-subtle)] bg-[var(--color-bg-card)] py-20 transition-all duration-150">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12 space-y-12">
      <!-- Section Header -->
      <div class="text-center space-y-2 max-w-xl mx-auto">
        <span class="text-[12px] text-[var(--color-accent)] font-semibold uppercase tracking-wider block">Workflow</span>
        <h2 class="text-[28px] font-bold text-[var(--color-text-primary)]">Three Simple Steps</h2>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <!-- Step 1 -->
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-full bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.2)] text-[var(--color-accent)] text-[18px] font-bold flex items-center justify-center mx-auto">
            1
          </div>
          <h3 class="text-[16px] font-bold text-[var(--color-text-primary)]">Select Guidelines</h3>
          <p class="text-[14px] text-[var(--color-text-secondary)] leading-relaxed max-w-xs mx-auto">
            Pick from our database of 100+ recruitment exams, or configure a custom pixel width and Kilobyte target.
          </p>
        </div>
        
        <!-- Step 2 -->
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-full bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.2)] text-[var(--color-accent)] text-[18px] font-bold flex items-center justify-center mx-auto">
            2
          </div>
          <h3 class="text-[16px] font-bold text-[var(--color-text-primary)]">Upload Your Image</h3>
          <p class="text-[14px] text-[var(--color-text-secondary)] leading-relaxed max-w-xs mx-auto">
            Drag and drop your file. Crop, adjust brightness/contrast, or print credentials (name & date) on a bottom strip.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="space-y-4">
          <div class="w-12 h-12 rounded-full bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.2)] text-[var(--color-accent)] text-[18px] font-bold flex items-center justify-center mx-auto">
            3
          </div>
          <h3 class="text-[16px] font-bold text-[var(--color-text-primary)]">Process & Download</h3>
          <p class="text-[14px] text-[var(--color-text-secondary)] leading-relaxed max-w-xs mx-auto">
            Our binary search quality loop automatically compresses files to fit targets. Preview compare and download.
          </p>
        </div>
      </div>
    </div>
  </section>





  <!-- FAQ Section (Accordion) -->
  <section class="border-t border-[var(--color-border-subtle)] py-20 transition-all duration-150">
    <div class="max-w-[760px] mx-auto px-6 space-y-12">
      <!-- Header -->
      <div class="text-center space-y-2">
        <span class="text-[12px] text-[var(--color-accent)] font-semibold uppercase tracking-wider block">Support</span>
        <h2 class="text-[28px] font-bold text-[var(--color-text-primary)]">Frequently Asked Questions</h2>
      </div>

      <!-- Accordion list -->
      <div class="space-y-3" id="faq-accordion">
        {faqs.map((faq, i) => (
          <div class="accordion-item border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] overflow-hidden">
            <button
              type="button"
              class="accordion-trigger w-full flex items-center justify-between p-5 text-left text-[14px] font-bold text-[var(--color-text-primary)] focus:outline-none transition-colors duration-150 hover:bg-[var(--color-bg-elevated)]"
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
            >
              <span>{faq.q}</span>
              <svg class="w-4 h-4 text-[var(--color-text-secondary)] transform transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div
              id={`faq-answer-${i}`}
              class="accordion-panel hidden px-5 pb-5 pt-1 border-t border-[var(--color-border-subtle)] text-[13.5px] leading-relaxed text-[var(--color-text-secondary)] bg-[var(--color-bg-card)]"
            >
              <p>{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ JSON-LD Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  })} />
</Layout>

<script>

  // Handle FAQ Accordion Toggles
  const accordion = document.getElementById('faq-accordion');
  if (accordion) {
    const items = accordion.querySelectorAll('.accordion-item');

    items.forEach((item) => {
      const trigger = item.querySelector('.accordion-trigger') as HTMLButtonElement;
      const panel = item.querySelector('.accordion-panel') as HTMLElement;
      const arrow = trigger.querySelector('svg') as HTMLElement;

      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

        // Close all other panels first
        items.forEach((otherItem) => {
          const otherTrigger = otherItem.querySelector('.accordion-trigger') as HTMLButtonElement;
          const otherPanel = otherItem.querySelector('.accordion-panel') as HTMLElement;
          const otherArrow = otherTrigger.querySelector('svg') as HTMLElement;

          if (otherItem !== item) {
            otherTrigger.setAttribute('aria-expanded', 'false');
            otherPanel.classList.add('hidden');
            otherArrow.style.transform = 'rotate(0deg)';
          }
        });

        // Toggle current panel
        if (isExpanded) {
          trigger.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
          arrow.style.transform = 'rotate(0deg)';
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          panel.classList.remove('hidden');
          arrow.style.transform = 'rotate(180deg)';
        }
      });
    });
  }
</script>
