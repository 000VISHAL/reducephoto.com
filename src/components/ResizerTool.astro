    // Handle document type switching
    function setDocType(type: 'photo' | 'signature') {
      if (activeDocType === type) return;
      activeDocType = type;
      if (type === 'photo') {
        btnDocPhoto.className = "py-1.5 text-[13px] font-medium rounded-[4px] text-[var(--color-accent)] bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.15)] transition-all";
        btnDocSig.className = "py-1.5 text-[13px] font-medium rounded-[4px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] border border-transparent transition-all";
      } else {
        btnDocSig.className = "py-1.5 text-[13px] font-medium rounded-[4px] text-[var(--color-accent)] bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.15)] transition-all";
        btnDocPhoto.className = "py-1.5 text-[13px] font-medium rounded-[4px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] border border-transparent transition-all";
      }

      // Reset the uploaded file so it goes back to upload (re-upload) mode for the new document type
      const removeBtnInside = root.querySelector('#resizer-upload-remove-btn') as HTMLButtonElement;
      if (removeBtnInside) {
        removeBtnInside.click();
      }

      applyPresetValues();
    }

    btnDocPhoto?.addEventListener('click', () => setDocType('photo'));
    btnDocSig?.addEventListener('click', () => setDocType('signature'));

    // Apply active preset parameters to fields
    function applyPresetValues() {
      if (!activePreset) return;
      const specs = activeDocType === 'photo' ? activePreset.photo : activePreset.signature;
      
      inputWidth.value = specs.width.toString();
      inputHeight.value = specs.height.toString();
      inputMinKb.value = specs.minKB.toString();
      inputMaxKb.value = specs.maxKB.toString();
      selectFormat.value = specs.format;

      presetLabel.textContent = `${activePreset.name} (${activeDocType === 'photo' ? 'Photo' : 'Signature'})`;

      if (specs.notes) {
        requirementsCard.classList.remove('hidden');
        requirementsNotes.textContent = specs.notes;
      } else {
        requirementsCard.classList.add('hidden');
      }

      // Update crop preview aspect ratio since dimensions changed
