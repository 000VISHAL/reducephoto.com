        updateCropPreview();
      }
    }

    // Capture preset selected event
    root.addEventListener('exam-selected', (e: any) => {
      const data = e.detail;
      if (data.id === 'custom') {
        activePreset = null;
        docTypeContainer.classList.add('hidden');
        requirementsCard.classList.add('hidden');
        presetLabel.textContent = "Custom size selected";
      } else {
        activePreset = data;
        docTypeContainer.classList.remove('hidden');
        applyPresetValues();
      }
    });

    // Capture file selected event
    root.addEventListener('file-selected', (e: any) => {
      selectedFile = e.detail;
      uploadStatus.textContent = "Image uploaded";
      uploadStatus.className = "text-[12px] bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.15)] px-2 py-0.5 rounded-[4px] text-[var(--color-accent)]";
      
      btnProcess.classList.remove('hidden');

      // Reset shift percentages
      shiftX = 0.5;
      shiftY = 0.5;
      sliderCropVert.value = "50";
      valCropVert.textContent = "50%";
      sliderCropHoriz.value = "50";
      valCropHoriz.textContent = "50%";

      // Update the preview frame
      updateCropPreview();
    });

    root.addEventListener('file-removed', () => {
      selectedFile = null;
      uploadStatus.textContent = "Waiting for file";
      uploadStatus.className = "text-[12px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)] px-2 py-0.5 rounded-[4px] text-[var(--color-text-secondary)]";
      
      btnProcess.classList.add('hidden');
      cropPositionPanel.classList.add('hidden');
      hideProcessedResults();
    });

    // Manual dimension change listeners
    inputWidth?.addEventListener('input', () => {
      if (selectedFile) updateCropPreview();
    });
    inputHeight?.addEventListener('input', () => {
      if (selectedFile) updateCropPreview();
    });

    // Update crop preview on window resize
    window.addEventListener('resize', () => {
      if (selectedFile) updateCropPreview();
    });

    // Slider inputs for crop adjustment
    sliderCropVert?.addEventListener('input', (e) => {
      shiftY = parseInt((e.target as HTMLInputElement).value) / 100;
      valCropVert.textContent = `${Math.round(shiftY * 100)}%`;
      cropPreviewImg.style.top = `${-excessHeight * shiftY}px`;
      if (processedDataUrl) {
        processImage(true);
      }
    });

    sliderCropHoriz?.addEventListener('input', (e) => {
      shiftX = parseInt((e.target as HTMLInputElement).value) / 100;
      valCropHoriz.textContent = `${Math.round(shiftX * 100)}%`;
      cropPreviewImg.style.left = `${-excessWidth * shiftX}px`;
      if (processedDataUrl) {
        processImage(true);
      }
    });

    // Dragging events for crop preview image
    let isDraggingImage = false;
    let dragStartX = 0;
    let dragStartY = 0;
    let dragStartShiftX = 0;
    let dragStartShiftY = 0;
    let excessWidth = 0;
    let excessHeight = 0;

    cropPreviewContainer?.addEventListener('mousedown', (e) => {
      if (excessWidth <= 0 && excessHeight <= 0) return;
      isDraggingImage = true;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      dragStartShiftX = shiftX;
      dragStartShiftY = shiftY;
      cropPreviewContainer.classList.remove('cursor-grab');
      cropPreviewContainer.classList.add('cursor-grabbing');
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDraggingImage) return;
      
      const deltaX = e.clientX - dragStartX;
      const deltaY = e.clientY - dragStartY;

      if (excessWidth > 0) {
        const newShiftX = dragStartShiftX - (deltaX / excessWidth);
        shiftX = Math.max(0, Math.min(1, newShiftX));
        sliderCropHoriz.value = Math.round(shiftX * 100).toString();
        valCropHoriz.textContent = `${Math.round(shiftX * 100)}%`;
      }

      if (excessHeight > 0) {
        const newShiftY = dragStartShiftY - (deltaY / excessHeight);
        shiftY = Math.max(0, Math.min(1, newShiftY));
        sliderCropVert.value = Math.round(shiftY * 100).toString();
        valCropVert.textContent = `${Math.round(shiftY * 100)}%`;
      }

      cropPreviewImg.style.left = `${-excessWidth * shiftX}px`;
      cropPreviewImg.style.top = `${-excessHeight * shiftY}px`;

      if (processedDataUrl) {
        processImage(true);
      }
    });

    window.addEventListener('mouseup', () => {
      if (isDraggingImage) {
        isDraggingImage = false;
        cropPreviewContainer.classList.remove('cursor-grabbing');
        cropPreviewContainer.classList.add('cursor-grab');
        processImage(true);
      }
    });

    // Touch events for mobile compatibility
    cropPreviewContainer?.addEventListener('touchstart', (e) => {
      if (excessWidth <= 0 && excessHeight <= 0) return;
      isDraggingImage = true;
      dragStartX = e.touches[0].clientX;
      dragStartY = e.touches[0].clientY;
      dragStartShiftX = shiftX;
      dragStartShiftY = shiftY;
    }, { passive: true });

    cropPreviewContainer?.addEventListener('touchmove', (e) => {
      if (!isDraggingImage) return;
      
      const deltaX = e.touches[0].clientX - dragStartX;
      const deltaY = e.touches[0].clientY - dragStartY;

      if (excessWidth > 0) {
        const newShiftX = dragStartShiftX - (deltaX / excessWidth);
        shiftX = Math.max(0, Math.min(1, newShiftX));
        sliderCropHoriz.value = Math.round(shiftX * 100).toString();
        valCropHoriz.textContent = `${Math.round(shiftX * 100)}%`;
      }

      if (excessHeight > 0) {
        const newShiftY = dragStartShiftY - (deltaY / excessHeight);
        shiftY = Math.max(0, Math.min(1, newShiftY));
        sliderCropVert.value = Math.round(shiftY * 100).toString();
        valCropVert.textContent = `${Math.round(shiftY * 100)}%`;
      }

      cropPreviewImg.style.left = `${-excessWidth * shiftX}px`;
      cropPreviewImg.style.top = `${-excessHeight * shiftY}px`;

      if (processedDataUrl) {
        processImage(true);
      }
    }, { passive: true });

    cropPreviewContainer?.addEventListener('touchend', () => {
      if (isDraggingImage) {
        isDraggingImage = false;
        processImage(true);
      }
    });

    // Update crop preview position, boundaries, and image scaling
    function updateCropPreview() {
      if (!selectedFile) {
        cropPositionPanel.classList.add('hidden');
        return;
      }

      const isAlreadyVisible = !cropPositionPanel.classList.contains('hidden');
      cropPositionPanel.classList.remove('hidden');

      const performUpdate = () => {
        if (!selectedFile) return;

        const targetWidth = parseInt(inputWidth.value) || 350;
        const targetHeight = parseInt(inputHeight.value) || 450;

        const wrapperWidth = cropPreviewWrapper.clientWidth || 350;
        const maxWrapperHeight = 260; 
        const targetAspect = targetWidth / targetHeight;
        const wrapperAspect = wrapperWidth / maxWrapperHeight;

        let containerWidth, containerHeight;
        if (targetAspect > wrapperAspect) {
          containerWidth = wrapperWidth;
          containerHeight = wrapperWidth / targetAspect;
        } else {
          containerHeight = maxWrapperHeight;
          containerWidth = maxWrapperHeight * targetAspect;
        }

        cropPreviewContainer.style.width = `${containerWidth}px`;
        cropPreviewContainer.style.height = `${containerHeight}px`;

        cropPreviewImg.src = selectedFile.dataUrl;

        const scale = Math.max(containerWidth / selectedFile.width, containerHeight / selectedFile.height);
        const scaledWidth = selectedFile.width * scale;
        const scaledHeight = selectedFile.height * scale;

        cropPreviewImg.style.width = `${scaledWidth}px`;
        cropPreviewImg.style.height = `${scaledHeight}px`;

        excessWidth = scaledWidth - containerWidth;
        excessHeight = scaledHeight - containerHeight;

        // Toggle sliders visibility
        if (excessWidth > 1) {
          sliderHorizContainer.classList.remove('hidden');
        } else {
          sliderHorizContainer.classList.add('hidden');
        }

        if (excessHeight > 1) {
          sliderVertContainer.classList.remove('hidden');
        } else {
          sliderVertContainer.classList.add('hidden');
        }

        // Keep within bounds
        cropPreviewImg.style.left = `${-excessWidth * shiftX}px`;
        cropPreviewImg.style.top = `${-excessHeight * shiftY}px`;
      };

      if (isAlreadyVisible) {
        performUpdate();
      } else {
        // Let layout settle, then calculate dimensions
        setTimeout(performUpdate, 20);
      }
    }

    // Hide processed previews
    function hideProcessedResults() {
      comparisonContainer.classList.add('hidden');
      textOverlayPanel.classList.add('hidden');
      btnDownload.classList.add('hidden');
      btnShortcutText.classList.add('hidden');
      btnReset.classList.add('hidden');
      btnShare.classList.add('hidden');
    }

    // Share button copy link logic
    btnShare?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href);
      const originalText = btnShare.textContent;
      btnShare.textContent = "Link Copied!";
      setTimeout(() => {
        btnShare.textContent = originalText;
      }, 2000);
    });

    // Shortcut: open text overlays
    btnShortcutText?.addEventListener('click', () => {
      textOverlayPanel.classList.remove('hidden');
      textOverlayPanel.scrollIntoView({ behavior: 'smooth' });
      processImage(true);
    });

    // Close text overlay panel
    const btnCloseTextPanel = root.querySelector('#btn-close-text-panel') as HTMLButtonElement;
    btnCloseTextPanel?.addEventListener('click', () => {
      textOverlayPanel.classList.add('hidden');
      processImage(true);
    });

    // Text inputs real-time rendering
    textName?.addEventListener('input', () => {
      textName.value = textName.value.toUpperCase();
      processImage(true);
    });
    textDate?.addEventListener('input', () => processImage(true));
    textToggles?.forEach(radio => {
      radio.addEventListener('change', () => processImage(true));
    });

    // Main process action
    btnProcess?.addEventListener('click', () => {
      processImage(false);
    });

    btnReset?.addEventListener('click', () => {
      // Trigger removal in Dropzone component
      const removeBtnInside = root.querySelector('#resizer-upload-remove-btn') as HTMLButtonElement;
      if (removeBtnInside) removeBtnInside.click();
    });

    // Trigger preselected preset on startup
    if (preselectedId) {
      setTimeout(() => {
        const item = root.querySelector(`.preset-item[data-id="${preselectedId}"]`) as HTMLElement;
        if (item) item.click();
      }, 100);
    }

    // MAIN RESIZING ALGORITHM
    function processImage(isTextOnlyUpdate = false) {
      if (!selectedFile) return;

      const targetWidth = parseInt(inputWidth.value);
      const targetHeight = parseInt(inputHeight.value);
      const minKB = parseInt(inputMinKb.value);
      const maxKB = parseInt(inputMaxKb.value);
      const format = selectFormat.value === 'png' ? 'png' : (selectFormat.value === 'webp' ? 'webp' : 'jpeg');

      if (!targetWidth || !targetHeight) {
        alert('Please enter valid width and height dimensions.');
        return;
      }

      // Show loader
      if (!isTextOnlyUpdate) {
        progressContainer.classList.remove('hidden');
        btnProcess.classList.add('hidden');
      }

      const img = new Image();
      img.onload = () => {
        // Create canvas
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        canvas.width = targetWidth;
        canvas.height = targetHeight;

        // Apply white background if toggled
        if (toggleWhiteBg.checked) {
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, targetWidth, targetHeight);
        }

        // Draw image scaled (Fit with crop or stretching?)
        // Let's do a cover fit to avoid distortion, or stretch?
        // Candidates usually want no distortion, so let's preserve aspect ratio and cover the image!
        // We use shiftX and shiftY (set by the interactive crop box) to position the crop window.
        const hRatio = targetWidth / img.width;
        const vRatio = targetHeight / img.height;
        const ratio = Math.max(hRatio, vRatio);
        const scaledW = img.width * ratio;
        const scaledH = img.height * ratio;
        const centerShift_x = (targetWidth - scaledW) * shiftX;
        const centerShift_y = (targetHeight - scaledH) * shiftY;

        ctx.drawImage(img, 0, 0, img.width, img.height, centerShift_x, centerShift_y, scaledW, scaledH);

        // Apply background removal to turn grey/off-white background pure white if toggled
        if (toggleWhiteBg.checked) {
          const imgData = ctx.getImageData(0, 0, targetWidth, targetHeight);
          const data = imgData.data;
          const w = targetWidth;
          const h = targetHeight;
          const originalData = new Uint8ClampedArray(data);
          const visited = new Uint8Array(w * h);
          const queue: number[] = [];

          // Sample seeds along borders (top, left, right)
          const seeds: [number, number][] = [];
          for (let x = 0; x < w * 0.35; x += 4) {
            seeds.push([x, 0]);
            seeds.push([w - 1 - x, 0]);
          }
          for (let y = 0; y < h * 0.85; y += 4) {
            seeds.push([0, y]);
            seeds.push([w - 1, y]);
          }

          const validSeeds: { x: number; y: number; r: number; g: number; b: number }[] = [];
          seeds.forEach(([sx, sy]) => {
            const idx = (sy * w + sx) * 4;
            const r = originalData[idx];
            const g = originalData[idx + 1];
            const b = originalData[idx + 2];
            const brightness = (r + g + b) / 3;
            
            const maxVal = Math.max(r, g, b);
            const minVal = Math.min(r, g, b);
            const sat = maxVal === 0 ? 0 : (maxVal - minVal) / maxVal;

            // In Resizer, we can be a bit more flexible with brightness (e.g. brightness > 80)
            if (brightness > 80 && sat < 0.6) {
              validSeeds.push({ x: sx, y: sy, r, g, b });
            }
          });

          if (validSeeds.length === 0) {
            const corners = [
              [0, 0],
              [w - 1, 0],
              [0, h - 1],
              [w - 1, h - 1]
            ];
            corners.forEach(([cx, cy]) => {
              const idx = (cy * w + cx) * 4;
              validSeeds.push({ x: cx, y: cy, r: originalData[idx], g: originalData[idx+1], b: originalData[idx+2] });
            });
          }

          const sensitivity = 35; // Default standard threshold
          const maxDistSq = sensitivity * sensitivity * 3;

          validSeeds.forEach((seed) => {
            const key = seed.y * w + seed.x;
            if (visited[key]) return;

            visited[key] = 1;
            queue.push(seed.x, seed.y);

            const startR = seed.r;
            const startG = seed.g;
            const startB = seed.b;

            let qHead = 0;
            while (qHead < queue.length) {
              const x = queue[qHead++];
              const y = queue[qHead++];

              const idx = (y * w + x) * 4;
              data[idx] = 255;
              data[idx + 1] = 255;
              data[idx + 2] = 255;
              data[idx + 3] = 255;

              const neighbors = [
                [x + 1, y],
                [x - 1, y],
                [x, y + 1],
                [x, y - 1]
              ];

              for (let i = 0; i < neighbors.length; i++) {
                const nx = neighbors[i][0];
                const ny = neighbors[i][1];

                if (nx >= 0 && nx < w && ny >= 0 && ny < h) {
                  const nkey = ny * w + nx;
                  if (!visited[nkey]) {
                    const nIdx = nkey * 4;
                    const r = originalData[nIdx];
                    const g = originalData[nIdx + 1];
                    const b = originalData[nIdx + 2];
                    const a = originalData[nIdx + 3];

                    if (a < 10) {
                      visited[nkey] = 1;
                      queue.push(nx, ny);
                      continue;
                    }

                    const dr = r - startR;
                    const dg = g - startG;
                    const db = b - startB;
                    const distSq = dr * dr + dg * dg + db * db;

                    if (distSq <= maxDistSq) {
                      visited[nkey] = 1;
                      queue.push(nx, ny);
                    }
                  }
                }
              }
            }
            queue.length = 0;
          });

          ctx.putImageData(imgData, 0, 0);
        }

        // Adjust Brightness & Contrast
        const brightness = parseInt(bldBrightness.value);
        const contrast = parseInt(bldContrast.value);

        if (brightness !== 0 || contrast !== 0) {
          const imgData = ctx.getImageData(0, 0, targetWidth, targetHeight);
          const data = imgData.data;
          // Contrast factor
          const factor = (259 * (contrast + 255)) / (255 * (259 - contrast));

          for (let i = 0; i < data.length; i += 4) {
            // R, G, B channels
            for (let j = 0; j < 3; j++) {
              let v = data[i + j];
              // Brightness
              if (brightness !== 0) {
                v += brightness;
              }
              // Contrast
              if (contrast !== 0) {
                v = factor * (v - 128) + 128;
              }
              // Clamp
              data[i + j] = Math.min(255, Math.max(0, v));
            }
          }
          ctx.putImageData(imgData, 0, 0);
        }

        // Add Name & Date if text overlays are populated
        const includeName = textName && textName.value.trim().length > 0;
        const includeDate = textDate && textDate.value.trim().length > 0;
        
        let shouldDrawStrip = false;
        const isPanelActive = textOverlayPanel && !textOverlayPanel.classList.contains('hidden');

        if (isPanelActive) {
          let selectedToggle = 'both';
          textToggles.forEach(r => { if (r.checked) selectedToggle = r.value; });

          if (selectedToggle === 'both' && (includeName || includeDate)) shouldDrawStrip = true;
          if (selectedToggle === 'name' && includeName) shouldDrawStrip = true;
          if (selectedToggle === 'date' && includeDate) shouldDrawStrip = true;
        }

        if (shouldDrawStrip) {
          const stripHeight = Math.round(targetHeight * 0.20); // 20% of image height
          
          // Draw white strip
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, targetHeight - stripHeight, targetWidth, stripHeight);

          // Draw outline border for the strip
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = 1;
          ctx.strokeRect(0, targetHeight - stripHeight, targetWidth, stripHeight);

          // Text styling
          ctx.fillStyle = '#000000';
          ctx.textAlign = 'center';
          
          // Calculate font size
          const nameFontSize = Math.max(10, Math.round(stripHeight * 0.35));
          const dateFontSize = Math.max(9, Math.round(stripHeight * 0.30));

          if (selectedToggle === 'both' && includeName && includeDate) {
            // Draw name at top of strip
            ctx.font = `bold ${nameFontSize}px Arial`;
            ctx.fillText(textName.value.toUpperCase(), targetWidth / 2, targetHeight - stripHeight + (stripHeight * 0.4));
            
            // Draw date formatted (DD/MM/YYYY)
            ctx.font = `bold ${dateFontSize}px Arial`;
            const dateVal = new Date(textDate.value);
            const formattedDate = isNaN(dateVal.getTime()) 
              ? textDate.value 
              : `${String(dateVal.getDate()).padStart(2, '0')}/${String(dateVal.getMonth() + 1).padStart(2, '0')}/${dateVal.getFullYear()}`;
            ctx.fillText(`DATE OF PHOTO: ${formattedDate}`, targetWidth / 2, targetHeight - stripHeight + (stripHeight * 0.8));
          } else if (selectedToggle === 'name' && includeName) {
            // Draw name vertically centered
            ctx.font = `bold ${nameFontSize}px Arial`;
            ctx.fillText(textName.value.toUpperCase(), targetWidth / 2, targetHeight - (stripHeight / 2) + (nameFontSize / 3));
          } else if (selectedToggle === 'date' && includeDate) {
            // Draw date vertically centered
            ctx.font = `bold ${nameFontSize}px Arial`;
            const dateVal = new Date(textDate.value);
            const formattedDate = isNaN(dateVal.getTime()) 
              ? textDate.value 
              : `${String(dateVal.getDate()).padStart(2, '0')}/${String(dateVal.getMonth() + 1).padStart(2, '0')}/${dateVal.getFullYear()}`;
            ctx.fillText(`DOP: ${formattedDate}`, targetWidth / 2, targetHeight - (stripHeight / 2) + (nameFontSize / 3));
          }
        }

        // COMPRESSION BINARY SEARCH LOOP (client side only)
        // start at quality=0.9, adjust until size is within minKB-maxKB
        let quality = 0.9;
        let finalDataUrl = '';
        let fileSizeKB = 0;
        let iterations = 0;
        const maxIterations = 10;

        const mime = `image/${format}`;

        if (format === 'png') {
          // PNG does not support quality compression parameter
          finalDataUrl = canvas.toDataURL(mime);
          fileSizeKB = Math.round((finalDataUrl.length * 0.75) / 1024);
        } else {
          let minQuality = 0.01;
          let maxQuality = 1.0;

          while (iterations < maxIterations) {
            finalDataUrl = canvas.toDataURL(mime, quality);
            fileSizeKB = (finalDataUrl.length * 0.75) / 1024;

            if (fileSizeKB > maxKB) {
              // Too large, decrease quality limit
              maxQuality = quality;
              quality = (quality + minQuality) / 2;
            } else if (fileSizeKB < minKB && quality < 0.95) {
              // Too small, increase quality limit
              minQuality = quality;
              quality = (quality + maxQuality) / 2;
            } else {
              // Within limits or max quality reached
              break;
            }
            iterations++;
          }
        }

        // Output results
        processedDataUrl = finalDataUrl;
        btnDownload.href = finalDataUrl;
        
        // Dynamic name for downloading
        let downloadName = 'reducephoto-resized.' + format;
        if (activePreset) {
          downloadName = `${activePreset.id}-${activeDocType}-${targetWidth}x${targetHeight}.${format}`;
        }
        btnDownload.download = downloadName;

        // Render Before After comparison slider
        renderComparisonSlider(selectedFile.dataUrl, finalDataUrl);

        // Update stats
        valOrigDims.textContent = `${selectedFile.width} x ${selectedFile.height} px`;
        valOrigSize.textContent = `${selectedFile.sizeKB} KB`;
        valProcDims.textContent = `${targetWidth} x ${targetHeight} px`;
        valProcSize.textContent = `${Math.round(fileSizeKB)} KB`;

        // Adjust UI
        if (!isTextOnlyUpdate) {
          // Fade progress bar out
          const fill = root.querySelector('#resizer-progress-fill') as HTMLElement;
          const label = root.querySelector('#resizer-progress-label') as HTMLElement;
          const percent = root.querySelector('#resizer-progress-percent') as HTMLElement;
          
          if (fill && label && percent) {
            fill.style.width = '100%';
            percent.textContent = '100%';
            label.textContent = 'Image compressed successfully!';
          }

          setTimeout(() => {
            progressContainer.classList.add('hidden');
            comparisonContainer.classList.remove('hidden');
            
            // Only show name and date option if editing a photograph
            if (activeDocType === 'photo') {
              btnShortcutText.classList.remove('hidden');
            } else {
              btnShortcutText.classList.add('hidden');
              textOverlayPanel.classList.add('hidden');
            }

            btnDownload.classList.remove('hidden');
            btnReset.classList.remove('hidden');
            btnShare.classList.remove('hidden');
          }, 350);
        }
      };
      img.src = selectedFile.dataUrl;
    }

    function renderComparisonSlider(origUrl: string, procUrl: string) {
      // Create slider HTML dynamically to mount
      comparisonMount.innerHTML = `
        <div class="before-after-slider relative overflow-hidden border border-[var(--color-border)] rounded-[8px] aspect-[4/3] w-full max-w-lg mx-auto bg-black select-none">
          <img src="${origUrl}" class="absolute inset-0 w-full h-full object-contain pointer-events-none" alt="Original Image" />
          <span class="absolute top-3 left-3 text-[11px] font-semibold uppercase tracking-wider bg-black/60 border border-[var(--color-border)] text-[var(--color-text-secondary)] px-2 py-0.5 rounded-[4px]">
            Original
          </span>

          <div class="processed-container absolute inset-0 w-full h-full overflow-hidden pointer-events-none" style="width: 50%;">
            <img src="${procUrl}" class="absolute inset-0 w-full h-full object-contain pointer-events-none max-w-none" style="width: 100%; height: 100%;" alt="Processed Image" />
            <span class="absolute top-3 right-3 text-[11px] font-semibold uppercase tracking-wider bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.2)] text-[var(--color-accent)] px-2 py-0.5 rounded-[4px]">
              Processed
            </span>
          </div>

          <div class="slider-divider absolute top-0 bottom-0 left-[50%] w-[2px] bg-white pointer-events-none">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full flex items-center justify-center pointer-events-none border border-[var(--color-border)]">
              <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9"></path>
              </svg>
            </div>
          </div>

          <input
            type="range"
            min="0"
            max="100"
            value="50"
            class="slider-input absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-10"
            aria-label="Before after comparison slider"
          />
        </div>
      `;

      // Active comparison scripts on newly created element
      const slider = comparisonMount.querySelector('.before-after-slider') as HTMLElement;
      const rangeInput = slider.querySelector('.slider-input') as HTMLInputElement;
      const processedContainer = slider.querySelector('.processed-container') as HTMLElement;
      const divider = slider.querySelector('.slider-divider') as HTMLElement;
      const processedImg = processedContainer.querySelector('img') as HTMLElement;

      function updateSlider(val: string) {
        processedContainer.style.width = `${val}%`;
        divider.style.left = `${val}%`;
      }

      rangeInput.addEventListener('input', (e) => {
        const val = (e.target as HTMLInputElement).value;
        updateSlider(val);
      });

      const resizeObserver = new ResizeObserver(entries => {
        for (let entry of entries) {
          const width = entry.contentRect.width;
          const height = entry.contentRect.height;
          if (processedImg) {
            processedImg.style.width = `${width}px`;
            processedImg.style.height = `${height}px`;
          }
        }
      });
      resizeObserver.observe(slider);
      
      updateSlider(rangeInput.value);
    }
  }
</script>
