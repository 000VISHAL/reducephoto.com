---
import ExamSearch from './ExamSearch.astro';
import ImageDropzone from './ImageDropzone.astro';
import ProgressBar from './ProgressBar.astro';
import BeforeAfterSlider from './BeforeAfterSlider.astro';

interface Props {
  preselectedExamId?: string;
}

const { preselectedExamId = "" } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start" id="resizer-tool-root" data-preselected={preselectedExamId}>
  <!-- Left Side: Config & Options (5 cols) -->
  <div class="lg:col-span-5 space-y-6">
    <!-- Preset Selection Card -->
    <div class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] p-5 space-y-4">
      <div class="flex items-center gap-2">
        <span class="w-5 h-5 rounded-full bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.2)] text-[var(--color-accent)] text-[12px] font-bold flex items-center justify-center">1</span>
        <h2 class="text-[16px] font-bold text-[var(--color-text-primary)]">Exam or Size Settings</h2>
      </div>
      
      <!-- Preset dropdown selection -->
      <ExamSearch />

      <!-- Doc Type Toggle (only visible if preset is selected) -->
      <div id="doc-type-container" class="hidden space-y-2 pt-2 border-t border-[var(--color-border-subtle)]">
        <span class="block text-[13px] font-medium text-[var(--color-text-secondary)]">Document Type</span>
        <div class="grid grid-cols-2 gap-2 bg-[var(--color-bg-input)] p-1 rounded-[6px] border border-[var(--color-border)]">
          <button type="button" id="btn-doc-photo" class="py-1.5 text-[13px] font-medium rounded-[4px] text-[var(--color-accent)] bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.15)] transition-all">
            Photograph
          </button>
          <button type="button" id="btn-doc-sig" class="py-1.5 text-[13px] font-medium rounded-[4px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] border border-transparent transition-all">
            Signature
          </button>
        </div>
      </div>

      <!-- Config Preview (Interactive Form) -->
      <div class="space-y-4 pt-3 border-t border-[var(--color-border-subtle)]">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="input-width" class="block text-[12px] text-[var(--color-text-secondary)] mb-1">Width (px)</label>
            <input type="number" id="input-width" value="350" class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3 py-1.5 text-[13px] text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] outline-none" />
          </div>
          <div>
            <label for="input-height" class="block text-[12px] text-[var(--color-text-secondary)] mb-1">Height (px)</label>
            <input type="number" id="input-height" value="450" class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3 py-1.5 text-[13px] text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] outline-none" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="input-minkb" class="block text-[12px] text-[var(--color-text-secondary)] mb-1">Min KB</label>
            <input type="number" id="input-minkb" value="20" class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3 py-1.5 text-[13px] text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] outline-none" />
          </div>
          <div>
            <label for="input-maxkb" class="block text-[12px] text-[var(--color-text-secondary)] mb-1">Max KB</label>
            <input type="number" id="input-maxkb" value="50" class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3 py-1.5 text-[13px] text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] outline-none" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="select-format" class="block text-[12px] text-[var(--color-text-secondary)] mb-1">Format</label>
            <select id="select-format" class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3 py-1.5 text-[13px] text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] outline-none">
              <option value="jpg">JPG / JPEG</option>
              <option value="png">PNG</option>
              <option value="webp">WEBP</option>
            </select>
          </div>
          <div class="flex items-end">
            <span class="text-[12px] text-[var(--color-text-muted)] pb-2" id="current-preset-label">Custom size selected</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Official Requirements Info Card (hidden unless preset selected) -->
    <div id="requirements-card" class="hidden border border-[var(--color-warning)]/30 bg-[var(--color-bg-card)] rounded-[8px] p-5 space-y-3">
      <div class="flex items-center gap-2 text-[var(--color-warning)] font-semibold text-[14px]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <span>Official Portal Requirements</span>
      </div>
      <p id="requirements-notes" class="text-[13px] text-[var(--color-text-secondary)] leading-relaxed"></p>
    </div>

    <!-- Collapsible Bonus Adjustments -->
    <div class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] p-5 space-y-4">
      <button type="button" id="toggle-adjustments" class="w-full flex items-center justify-between font-bold text-[14px] text-[var(--color-text-primary)] focus:outline-none">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
          <span>Advanced Adjustments (Optional)</span>
        </div>
        <svg class="w-4 h-4 transform transition-transform" id="adjustments-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>

      <div id="adjustments-panel" class="space-y-4 pt-3 border-t border-[var(--color-border-subtle)] hidden">
        <!-- Brightness Slider -->
        <div class="space-y-1.5">
          <div class="flex justify-between text-[12px]">
            <label for="slider-brightness" class="text-[var(--color-text-secondary)]">Brightness</label>
            <span id="val-brightness" class="text-[var(--color-text-primary)]">0</span>
          </div>
          <input type="range" id="slider-brightness" min="-50" max="50" value="0" class="w-full h-1 bg-[var(--color-border)] rounded-full appearance-none cursor-pointer accent-[var(--color-accent)]" />
        </div>

        <!-- Contrast Slider -->
        <div class="space-y-1.5">
          <div class="flex justify-between text-[12px]">
            <label for="slider-contrast" class="text-[var(--color-text-secondary)]">Contrast</label>
            <span id="val-contrast" class="text-[var(--color-text-primary)]">0</span>
          </div>
          <input type="range" id="slider-contrast" min="-50" max="50" value="0" class="w-full h-1 bg-[var(--color-border)] rounded-full appearance-none cursor-pointer accent-[var(--color-accent)]" />
        </div>

        <!-- White BG Toggle -->
        <div class="flex items-center justify-between pt-2">
          <div>
            <label for="toggle-whitebg" class="block text-[13px] font-semibold text-[var(--color-text-primary)]">Force White Background</label>
            <span class="block text-[11px] text-[var(--color-text-secondary)]">Replaces transparent/grey with pure white</span>
          </div>
          <input type="checkbox" id="toggle-whitebg" class="w-4 h-4 accent-[var(--color-accent)] cursor-pointer" />
        </div>
      </div>
    </div>
  </div>

  <!-- Right Side: Dropzone, Processing, Slider (7 cols) -->
  <div class="lg:col-span-7 space-y-6">
    <div class="border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] p-5 space-y-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="w-5 h-5 rounded-full bg-[var(--color-accent-subtle)] border border-[rgba(0,208,132,0.2)] text-[var(--color-accent)] text-[12px] font-bold flex items-center justify-center">2</span>
          <h2 class="text-[16px] font-bold text-[var(--color-text-primary)]">Upload & Process</h2>
        </div>
        <span class="text-[12px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)] px-2 py-0.5 rounded-[4px] text-[var(--color-text-secondary)]" id="upload-status">
          Waiting for file
        </span>
      </div>

      <!-- Dropzone -->
      <ImageDropzone id="resizer-upload" maxSizeMB={15} />

      <!-- Crop Position Adjustment Panel (shown when file is selected) -->
      <div id="crop-position-panel" class="hidden space-y-4 border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-card)] p-5">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[var(--color-accent)] animate-pulse" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path>
          </svg>
          <h3 class="text-[14px] font-bold text-[var(--color-text-primary)]">Adjust Crop Position</h3>
        </div>
        <p class="text-[12px] text-[var(--color-text-secondary)] leading-relaxed">
          Drag the photo up/down (or left/right) inside the frame to center your face or signature perfectly and avoid cutting off your head.
        </p>

        <div id="crop-preview-wrapper" class="relative w-full bg-[#050505] border border-[var(--color-border)] rounded-[6px] overflow-hidden flex items-center justify-center p-4 min-h-[150px] select-none">
          <!-- Draggable Crop Box Container -->
          <div id="crop-preview-container" class="relative overflow-hidden cursor-grab active:cursor-grabbing border border-[var(--color-accent)]/30 rounded-[4px] shadow-lg">
            <img id="crop-preview-img" class="absolute pointer-events-none max-w-none origin-top-left" alt="Crop position preview" />
            
            <!-- Target boundary glow/border -->
            <div class="absolute inset-0 pointer-events-none border border-[var(--color-accent)] opacity-60"></div>
            
            <!-- Grid lines for framing -->
            <div class="absolute inset-0 pointer-events-none grid grid-cols-3 grid-rows-3 opacity-25">
              <div class="border-b border-r border-dashed border-white"></div>
              <div class="border-b border-r border-dashed border-white"></div>
              <div class="border-b border-dashed border-white"></div>
              <div class="border-b border-r border-dashed border-white"></div>
              <div class="border-b border-r border-dashed border-white"></div>
              <div class="border-b border-dashed border-white"></div>
              <div class="border-r border-dashed border-white"></div>
              <div class="border-r border-dashed border-white"></div>
              <div></div>
            </div>
          </div>
        </div>

        <!-- Position Sliders for fine control -->
        <div class="grid grid-cols-1 gap-3 pt-2 border-t border-[var(--color-border-subtle)]">
          <div id="slider-vert-container" class="space-y-1.5">
            <div class="flex justify-between text-[12px]">
              <span class="text-[var(--color-text-secondary)] font-medium">Vertical Position (Up / Down)</span>
              <span id="val-crop-vert" class="text-[var(--color-text-primary)] font-semibold">50%</span>
            </div>
            <input type="range" id="slider-crop-vert" min="0" max="100" value="50" class="w-full h-1 bg-[var(--color-border)] rounded-full appearance-none cursor-pointer accent-[var(--color-accent)]" />
          </div>

          <div id="slider-horiz-container" class="space-y-1.5 hidden">
            <div class="flex justify-between text-[12px]">
              <span class="text-[var(--color-text-secondary)] font-medium">Horizontal Position (Left / Right)</span>
              <span id="val-crop-horiz" class="text-[var(--color-text-primary)] font-semibold">50%</span>
            </div>
            <input type="range" id="slider-crop-horiz" min="0" max="100" value="50" class="w-full h-1 bg-[var(--color-border)] rounded-full appearance-none cursor-pointer accent-[var(--color-accent)]" />
          </div>
        </div>
      </div>

      <!-- Progress bar (initially hidden) -->
      <div id="process-progress-container" class="hidden">
        <ProgressBar id="resizer-progress" />
      </div>

      <!-- Comparison Section (Initially hidden) -->
      <div id="comparison-container" class="hidden space-y-6">
        <div class="space-y-2">
          <h3 class="text-[14px] font-bold text-[var(--color-text-primary)]">Processed Preview</h3>
          <p class="text-[12px] text-[var(--color-text-secondary)]">Drag the slider horizontally to compare the original and processed images.</p>
        </div>

        <!-- Live slider -->
        <div id="comparison-slider-mount"></div>

        <!-- Dimensions confirmation & results details -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-[8px] p-4 text-[13px]">
          <div class="space-y-1">
            <span class="text-[11px] text-[var(--color-text-muted)] uppercase tracking-wider block">Original Image</span>
            <div class="text-[var(--color-text-primary)] font-medium" id="val-orig-dims">0 x 0 px</div>
            <div class="text-[var(--color-text-secondary)]" id="val-orig-size">0 KB</div>
          </div>
          <div class="space-y-1 border-t sm:border-t-0 sm:border-l border-[var(--color-border-subtle)] pt-3 sm:pt-0 sm:pl-4">
            <span class="text-[11px] text-[var(--color-text-muted)] uppercase tracking-wider block">Processed Output</span>
            <div class="text-[var(--color-accent)] font-semibold" id="val-proc-dims">0 x 0 px</div>
            <div class="text-[var(--color-text-secondary)]" id="val-proc-size">0 KB</div>
          </div>
        </div>
      </div>

      <!-- Live Canvas Drawer: Add Name & Date Section -->
      <div id="text-overlay-panel" class="hidden border border-[var(--color-border)] rounded-[8px] bg-[var(--color-bg-elevated)] p-4 space-y-4">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h4 class="text-[14px] font-bold text-[var(--color-text-primary)]">Add Name & Date strip</h4>
            <p class="text-[12px] text-[var(--color-text-secondary)]">Commonly required for UPSC and NEET registrations. Adds a white bottom panel containing credentials.</p>
          </div>
          <button type="button" id="btn-close-text-panel" class="text-[12px] font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-error)] border border-[var(--color-border)] hover:border-[var(--color-error)] px-2 py-1 rounded-[4px] bg-[var(--color-bg-card)] transition-colors" aria-label="Remove text overlay">
            Remove
          </button>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label for="text-name" class="block text-[12px] text-[var(--color-text-secondary)] mb-1">Candidate Name</label>
            <input type="text" id="text-name" placeholder="UPPERCASE LETTERS" class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3 py-1.5 text-[13px] text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] outline-none" />
          </div>
          <div>
            <label for="text-date" class="block text-[12px] text-[var(--color-text-secondary)] mb-1">Date of Photograph</label>
            <input type="date" id="text-date" class="w-full bg-[var(--color-bg-input)] border border-[var(--color-border)] rounded-[6px] px-3 py-1.5 text-[13px] text-[var(--color-text-primary)] focus:border-[var(--color-border-focus)] outline-none" />
          </div>
        </div>

        <div class="flex items-center gap-6">
          <label class="flex items-center gap-2 text-[13px] text-[var(--color-text-secondary)] cursor-pointer">
            <input type="radio" name="text-toggle" value="both" checked class="accent-[var(--color-accent)]" />
            <span>Include Both</span>
          </label>
          <label class="flex items-center gap-2 text-[13px] text-[var(--color-text-secondary)] cursor-pointer">
            <input type="radio" name="text-toggle" value="name" class="accent-[var(--color-accent)]" />
            <span>Name Only</span>
          </label>
          <label class="flex items-center gap-2 text-[13px] text-[var(--color-text-secondary)] cursor-pointer">
            <input type="radio" name="text-toggle" value="date" class="accent-[var(--color-accent)]" />
            <span>Date Only</span>
          </label>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-[var(--color-border-subtle)]">
        <!-- Main trigger -->
        <button
          type="button"
          id="btn-process"
          class="flex-1 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-[var(--color-text-inverse)] text-[14px] font-semibold py-2.5 rounded-[6px] transition-colors focus-ring disabled:opacity-40 disabled:cursor-not-allowed hidden"
        >
          Process Image
        </button>

        <!-- Download trigger -->
        <a
          href="#"
          id="btn-download"
          download="reducephoto-resized.jpg"
          class="flex-1 bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-[var(--color-text-inverse)] text-[14px] font-semibold py-2.5 rounded-[6px] transition-colors focus-ring text-center hidden"
        >
          Download Image
        </a>

        <!-- Add name and date shortcut -->
        <button
          type="button"
          id="btn-shortcut-text"
          class="border border-[var(--color-border)] hover:border-[var(--color-border-focus)] hover:bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] text-[13px] font-medium py-2 px-4 rounded-[6px] transition-colors hidden"
        >
          Add Name & Date
        </button>

        <!-- Process another -->
        <button
          type="button"
          id="btn-reset"
          class="border border-[var(--color-border)] hover:border-[var(--color-border-focus)] hover:bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] text-[13px] font-medium py-2 px-4 rounded-[6px] transition-colors hidden"
        >
          Process Another
        </button>

        <!-- Share (Copy Link) -->
        <button
          type="button"
          id="btn-share"
          class="border border-[var(--color-border)] hover:border-[var(--color-border-focus)] hover:bg-[var(--color-bg-elevated)] text-[var(--color-text-primary)] text-[13px] font-medium py-2 px-4 rounded-[6px] transition-colors hidden"
        >
          Share
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { exams } from '../data/exams';

  // State
  let selectedFile: { file: File; dataUrl: string; width: number; height: number; sizeKB: number } | null = null;
  let activePreset: any = null;
  let activeDocType: 'photo' | 'signature' = 'photo';
  let processedDataUrl: string | null = null;
  let shiftX = 0.5;
  let shiftY = 0.5;

  // DOM Elements
  const root = document.getElementById('resizer-tool-root');
  if (root) {
    const preselectedId = root.dataset.preselected;

    // Advanced adjustments
    const toggleAdjBtn = root.querySelector('#toggle-adjustments') as HTMLButtonElement;
    const adjPanel = root.querySelector('#adjustments-panel') as HTMLElement;
    const adjArrow = root.querySelector('#adjustments-arrow') as HTMLElement;

    const bldBrightness = root.querySelector('#slider-brightness') as HTMLInputElement;
    const valBrightness = root.querySelector('#val-brightness') as HTMLElement;
    const bldContrast = root.querySelector('#slider-contrast') as HTMLInputElement;
    const valContrast = root.querySelector('#val-contrast') as HTMLElement;
    const toggleWhiteBg = root.querySelector('#toggle-whitebg') as HTMLInputElement;

    // Document types
    const docTypeContainer = root.querySelector('#doc-type-container') as HTMLElement;
    const btnDocPhoto = root.querySelector('#btn-doc-photo') as HTMLButtonElement;
    const btnDocSig = root.querySelector('#btn-doc-sig') as HTMLButtonElement;

    // Direct inputs
    const inputWidth = root.querySelector('#input-width') as HTMLInputElement;
    const inputHeight = root.querySelector('#input-height') as HTMLInputElement;
    const inputMinKb = root.querySelector('#input-minkb') as HTMLInputElement;
    const inputMaxKb = root.querySelector('#input-maxkb') as HTMLInputElement;
    const selectFormat = root.querySelector('#select-format') as HTMLSelectElement;
    const presetLabel = root.querySelector('#current-preset-label') as HTMLElement;
    const requirementsCard = root.querySelector('#requirements-card') as HTMLElement;
    const requirementsNotes = root.querySelector('#requirements-notes') as HTMLElement;

    // Crop position adjustment DOM elements
    const cropPositionPanel = root.querySelector('#crop-position-panel') as HTMLElement;
    const cropPreviewWrapper = root.querySelector('#crop-preview-wrapper') as HTMLElement;
    const cropPreviewContainer = root.querySelector('#crop-preview-container') as HTMLElement;
    const cropPreviewImg = root.querySelector('#crop-preview-img') as HTMLImageElement;

    const sliderCropVert = root.querySelector('#slider-crop-vert') as HTMLInputElement;
    const valCropVert = root.querySelector('#val-crop-vert') as HTMLElement;
    const sliderCropHoriz = root.querySelector('#slider-crop-horiz') as HTMLInputElement;
    const valCropHoriz = root.querySelector('#val-crop-horiz') as HTMLElement;
    
    const sliderVertContainer = root.querySelector('#slider-vert-container') as HTMLElement;
    const sliderHorizContainer = root.querySelector('#slider-horiz-container') as HTMLElement;

    // Upload & Process flow
    const dropzoneArea = root.querySelector('#resizer-upload-area') as HTMLElement;
    const dropzoneInfo = root.querySelector('#resizer-upload-info') as HTMLElement;
    const uploadStatus = root.querySelector('#upload-status') as HTMLElement;
    const progressContainer = root.querySelector('#process-progress-container') as HTMLElement;
    const comparisonContainer = root.querySelector('#comparison-container') as HTMLElement;
    const comparisonMount = root.querySelector('#comparison-slider-mount') as HTMLElement;

    // Value outputs
    const valOrigDims = root.querySelector('#val-orig-dims') as HTMLElement;
    const valOrigSize = root.querySelector('#val-orig-size') as HTMLElement;
    const valProcDims = root.querySelector('#val-proc-dims') as HTMLElement;
    const valProcSize = root.querySelector('#val-proc-size') as HTMLElement;

    // Text Overlay
    const textOverlayPanel = root.querySelector('#text-overlay-panel') as HTMLElement;
    const textName = root.querySelector('#text-name') as HTMLInputElement;
