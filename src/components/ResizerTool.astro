    const btnDownload = root.querySelector('#btn-download') as HTMLAnchorElement;
    const btnShortcutText = root.querySelector('#btn-shortcut-text') as HTMLButtonElement;
    const btnReset = root.querySelector('#btn-reset') as HTMLButtonElement;
    const btnShare = root.querySelector('#btn-share') as HTMLButtonElement;

