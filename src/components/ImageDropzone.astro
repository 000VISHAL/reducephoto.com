---
interface Props {
  id?: string;
  accept?: string;
  maxSizeMB?: number;
}

const {
  id = "dropzone",
  accept = "image/jpeg,image/png,image/webp",
  maxSizeMB = 15
} = Astro.props;
---

<div class="space-y-4" id={`${id}-container`}>
  <!-- Dropzone Area -->
  <div
    id={`${id}-area`}
    class="relative border-2 border-dashed border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-[12px] bg-[var(--color-bg-card)] p-12 text-center cursor-pointer transition-all duration-150 outline-none focus-within:border-[var(--color-accent)] focus-within:ring-2 focus-within:ring-[var(--color-accent)] focus-within:ring-offset-2 focus-within:ring-offset-black"
    tabindex="0"
    role="button"
    aria-label="Upload image dropzone. Drag and drop your image file here or press Enter to browse files."
  >
    <input
      type="file"
      id={`${id}-input`}
      accept={accept}
      class="sr-only"
      tabindex="-1"
    />
    
    <div class="flex flex-col items-center justify-center space-y-3 pointer-events-none">
      <!-- Upload Icon (Lucide ArrowUpToLine / Upload) -->
      <svg class="w-8 h-8 text-[var(--color-text-muted)] dropzone-icon transition-colors duration-150" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
      </svg>
      
      <div class="space-y-1">
        <p class="text-[15px] font-medium text-[var(--color-text-secondary)] dropzone-text">
          Drag & drop or <span class="text-[var(--color-accent)] font-semibold">click to browse</span>
        </p>
        <p class="text-[12px] text-[var(--color-text-muted)]">
          Supports JPG, PNG, WEBP • Max {maxSizeMB}MB
        </p>
      </div>
    </div>
  </div>

  <!-- Uploaded File Info Card (Initially Hidden) -->
  <div id={`${id}-info`} class="hidden bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-[8px] p-4 flex items-center justify-between transition-all duration-150">
    <div class="flex items-center gap-3.5 min-w-0">
      <!-- File Preview (Thumb) -->
      <div class="w-12 h-12 rounded-[4px] border border-[var(--color-border)] bg-[var(--color-bg)] overflow-hidden flex-shrink-0 flex items-center justify-center">
        <img id={`${id}-preview`} class="w-full h-full object-cover hidden" alt="File preview" />
        <svg id={`${id}-preview-fallback`} class="w-6 h-6 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <polyline points="21 15 16 10 5 21"></polyline>
        </svg>
      </div>
      <!-- File Metadata -->
      <div class="min-w-0">
        <h5 id={`${id}-filename`} class="text-[14px] font-semibold text-[var(--color-text-primary)] truncate">image.jpg</h5>
        <p id={`${id}-meta`} class="text-[12px] text-[var(--color-text-secondary)]">0 x 0 px • 0 KB</p>
      </div>
    </div>
    
    <!-- Remove Button -->
    <button
      type="button"
      id={`${id}-remove-btn`}
      class="text-[var(--color-text-secondary)] hover:text-[var(--color-error)] p-1.5 rounded-[4px] hover:bg-[var(--color-bg-elevated)] transition-colors focus-ring"
      aria-label="Remove uploaded image"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="3 6 5 6 21 6"></polyline>
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
        <line x1="10" y1="11" x2="10" y2="17"></line>
        <line x1="14" y1="11" x2="14" y2="17"></line>
      </svg>
    </button>
  </div>
</div>

<style>
  /* Drag over styles */
  .drag-over {
    border-color: var(--color-accent) !important;
    background-color: var(--color-accent-subtle) !important;
  }
  .drag-over .dropzone-icon {
    color: var(--color-accent) !important;
  }
  .drag-over .dropzone-text {
    color: var(--color-text-primary) !important;
  }
</style>

<script define:vars={{ id, maxSizeMB }}>
  // Manage file dropzone
  const container = document.getElementById(`${id}-container`);
  if (container) {
    const dropArea = container.querySelector(`#${id}-area`);
    const fileInput = container.querySelector(`#${id}-input`);
    const infoCard = container.querySelector(`#${id}-info`);
    const filenameEl = container.querySelector(`#${id}-filename`);
    const metaEl = container.querySelector(`#${id}-meta`);
    const previewEl = container.querySelector(`#${id}-preview`);
    const previewFallbackEl = container.querySelector(`#${id}-preview-fallback`);
    const removeBtn = container.querySelector(`#${id}-remove-btn`);

    // Click trigger
    dropArea.addEventListener('click', () => {
      fileInput.click();
    });

    // Keyboard support (Enter/Space on dropzone)
    dropArea.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        fileInput.click();
      }
    });

    // Drag-over styling
    ['dragenter', 'dragover'].forEach(eventName => {
      dropArea.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropArea.classList.add('drag-over');
      }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropArea.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropArea.classList.remove('drag-over');
      }, false);
    });

    // Drop file
    dropArea.addEventListener('drop', (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      if (files.length > 0) {
        handleFileSelect(files[0]);
      }
    });

    // Input file select
    fileInput.addEventListener('change', (e) => {
      const files = e.target.files;
      if (files && files.length > 0) {
        handleFileSelect(files[0]);
      }
    });

    // Remove file
    removeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      resetDropzone();
    });

    function resetDropzone() {
      fileInput.value = '';
      infoCard.classList.add('hidden');
      dropArea.classList.remove('hidden');
      previewEl.src = '';
      previewEl.classList.add('hidden');
      previewFallbackEl.classList.remove('hidden');
      
      const event = new CustomEvent('file-removed', { bubbles: true });
      container.dispatchEvent(event);
    }

    function handleFileSelect(file) {
      // Validate file size
      if (file.size > maxSizeMB * 1024 * 1024) {
        alert(`File size exceeds ${maxSizeMB}MB limit. Please upload a smaller image.`);
        fileInput.value = '';
        return;
      }

      // Check if it is an image
      if (!file.type.startsWith('image/')) {
        alert('Unsupported file type. Please upload a valid image (JPG, PNG, or WEBP).');
        fileInput.value = '';
        return;
      }

      const reader = new FileReader();
      reader.onload = (event) => {
        const dataUrl = event.target.result;

        // Load image to get width and height
        const img = new Image();
        img.onload = () => {
          // Update visual file info
          filenameEl.textContent = file.name;
          const kbSize = Math.round(file.size / 1024);
          metaEl.textContent = `${img.width} x ${img.height} px • ${kbSize} KB`;
          
          previewEl.src = dataUrl;
          previewEl.classList.remove('hidden');
          previewFallbackEl.classList.add('hidden');
          
          dropArea.classList.add('hidden');
          infoCard.classList.remove('hidden');

          // Dispatch selection event
          const selectEvent = new CustomEvent('file-selected', {
            detail: {
              file: file,
              name: file.name,
              sizeBytes: file.size,
              sizeKB: kbSize,
              width: img.width,
              height: img.height,
              dataUrl: dataUrl
            },
            bubbles: true
          });
          container.dispatchEvent(selectEvent);
        };
        img.src = dataUrl;
      };
      reader.readAsDataURL(file);
    }
  }
</script>
