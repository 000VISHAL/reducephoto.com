---
const currentYear = new Date().getFullYear();
---
<footer class="bg-[var(--color-bg)] border-t border-[var(--color-border)] pt-16 pb-12 transition-all duration-150">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 mb-12">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 text-[var(--color-text-primary)] font-bold text-[18px] mb-4">
          <img src="/favicon-96x96.png" class="w-5 h-5 object-contain logo-icon" alt="" />
          <span>Reduce Photo Size</span>
        </div>
        <p class="text-[14px] text-[var(--color-text-secondary)] mb-6 max-w-sm">
          Privacy-first image formatting utility. Crop, resize, compress, and convert photos to official government exam guidelines directly inside your web browser.
        </p>

      </div>

      <!-- Column 1: Tools -->
      <div>
        <h4 class="text-[14px] font-semibold text-[var(--color-text-primary)] mb-4 uppercase tracking-wider">Tools</h4>
        <ul class="space-y-3 text-[14px]">
          <li><a href="/resizer" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Image Resizer</a></li>
          <li><a href="/crop" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Image Cropper</a></li>
          <li><a href="/convert" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Format Converter</a></li>
          <li><a href="/background-remove" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">BG Remover</a></li>
          <li><a href="/passport-print" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Passport Layout</a></li>
        </ul>
      </div>

      <!-- Column 2: Exams -->
      <div>
        <h4 class="text-[14px] font-semibold text-[var(--color-text-primary)] mb-4 uppercase tracking-wider">Exams</h4>
        <ul class="space-y-3 text-[14px]">
          <li><a href="/exam/upsc" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">UPSC Civil Services</a></li>
          <li><a href="/exam/ssc-cgl" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">SSC CGL</a></li>
          <li><a href="/exam/jee-main" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">JEE Main</a></li>
          <li><a href="/exam/neet-ug" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">NEET UG</a></li>
          <li><a href="/exams" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Browse All Exams</a></li>
        </ul>
      </div>

      <!-- Column 3: Legal & Resources -->
      <div>
        <h4 class="text-[14px] font-semibold text-[var(--color-text-primary)] mb-4 uppercase tracking-wider">Legal</h4>
        <ul class="space-y-3 text-[14px]">
          <li><a href="/about" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Contact Us</a></li>
          <li><a href="/privacy" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-0 border-t border-[var(--color-border-subtle)] my-8" />

    <!-- Bottom section -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-[13px] text-[var(--color-text-secondary)] text-center md:text-left">
        &copy; {currentYear} Reduce Photo Size. All rights reserved. Made in India.
      </div>
      <div class="text-[12px] text-[var(--color-text-muted)] text-center md:text-right max-w-md">
        All image processing happens locally in your browser. We never upload, save, or transmit your photos to any server. Zero server costs = 100% free forever.
      </div>
    </div>
  </div>
</footer>
